  "flows": [
    {
      "id": "FLOW_PROBLEMA_SAIA",
      "label": "Diagnóstico de Acceso SAIA",
      "start_node_id": "NODE_SAIA_START",
      "nodes": [
        {
          "id": "NODE_SAIA_START",
          "response": {
            "text": "¿Ya realizaste tu inscripción administrativa en el departamento de Caja?",
            "suggestions": ["Sí, ya pagué", "No, todavía no"]
          },
          "transitions": [
            {
              "phrases": [
                "sí",
                "ya pagué",
                "sí ya pagué",
                "pagué",
                "realicé el pago"
              ],
              "target_node_id": "NODE_SAIA_WAIT"
            },
            {
              "phrases": ["no", "todavía no", "aún no", "no he pagado"],
              "target_node_id": "NODE_SAIA_IR_CAJA"
            }
          ]
        },
        {
          "id": "NODE_SAIA_IR_CAJA",
          "response": {
            "text": "Debes completar primero el proceso administrativo en Caja. Una vez registrado el pago podrás acceder a los servicios académicos correspondientes.",
            "suggestions": ["Menú principal"]
          },
          "terminal": true
        },
        {
          "id": "NODE_SAIA_WAIT",
          "response": {
            "text": "¿Han transcurrido entre 48 y 72 horas desde que realizaste el pago?",
            "suggestions": ["Sí", "No"]
          },
          "transitions": [
            {
              "phrases": ["sí", "si", "ya pasó", "han pasado"],
              "target_node_id": "NODE_SAIA_SOPORTE"
            },
            {
              "phrases": ["no", "hoy pagué", "apenas pagué", "todavía no"],
              "target_node_id": "NODE_SAIA_ESPERAR"
            }
          ]
        },
        {
          "id": "NODE_SAIA_ESPERAR",
          "response": {
            "text": "Debes esperar el tiempo de procesamiento administrativo. Si después de 72 horas el problema continúa, vuelve a solicitar soporte.",
            "suggestions": ["Menú principal"]
          },
          "terminal": true
        },
        {
          "id": "NODE_SAIA_SOPORTE",
          "response": {
            "text": "Como ya realizaste el pago y transcurrió el tiempo de procesamiento, debes comunicarte con soporte académico para revisar tu acceso al sistema.",
            "suggestions": ["Menú principal"]
          },
          "terminal": true
        }
      ]
    },
    {
      "id": "FLOW_RECLAMO_ACTA",
      "label": "Reclamo por Ausencia en Acta",
      "start_node_id": "NODE_ACTA_START",
      "nodes": [
        {
          "id": "NODE_ACTA_START",
          "response": {
            "text": "¿Tienes a la mano tu comprobante de inscripción sellado por Caja?",
            "suggestions": ["Sí lo tengo", "No lo tengo"]
          },
          "transitions": [
            {
              "phrases": [
                "sí lo tengo",
                "lo tengo",
                "tengo el comprobante",
                "aquí lo tengo",
                "lo tengo sellado"
              ],
              "target_node_id": "NODE_ACTA_CONTROL"
            },
            {
              "phrases": [
                "no lo tengo",
                "no",
                "lo perdí",
                "no encuentro el comprobante"
              ],
              "target_node_id": "NODE_ACTA_BUSCAR"
            }
          ]
        },
        {
          "id": "NODE_ACTA_CONTROL",
          "response": {
            "text": "Dirígete a Control Académico con tu comprobante para que puedan verificar tu inscripción y corregir tu situación en el listado.",
            "suggestions": ["Menú principal"]
          },
          "terminal": true
        },
        {
          "id": "NODE_ACTA_BUSCAR",
          "response": {
            "text": "Debes solicitar una copia o validación de tu inscripción antes de iniciar el reclamo formal ante Control Académico.",
            "suggestions": ["Menú principal"]
          },
          "terminal": true
        }
      ]
    }
